NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_DEFAULT_EVENT_SLUG=avp-denver
NEXT_PUBLIC_EVENT_NAME="AVP Denver Open"
NEXT_PUBLIC_COURT_COUNT=8
NEXT_PUBLIC_DEFAULT_TIMEZONE=America/Denver

# MediaMTX self-hosted video (see docs/MEDIAMTX_DIGITALOCEAN_SETUP.md)
# WHEP base example: https://live.example.com (or http://1.2.3.4:8889 for testing)
# HLS base example: https://live.example.com/hls (or http://1.2.3.4:8888 for testing)
MEDIAMTX_WHEP_BASE_URL=
MEDIAMTX_HLS_BASE_URL=
MEDIAMTX_READ_USER=
MEDIAMTX_READ_PASS=
# Used by setup scripts/docs only, e.g. rtmp://1.2.3.4:1935
MEDIAMTX_RTMP_INGEST_BASE=

# Optional per-court MediaMTX path overrides (defaults: court{n}_preview and court{n}_program)
COURT_1_STREAM_PATH=
COURT_2_STREAM_PATH=
COURT_3_STREAM_PATH=
COURT_4_STREAM_PATH=
COURT_5_STREAM_PATH=
COURT_6_STREAM_PATH=
COURT_7_STREAM_PATH=
COURT_8_STREAM_PATH=

# Post-final overlay hold before auto-advancing to the next queued match
# (milliseconds, 0-3600000; blank/invalid falls back to 180000)
VBL_POST_FINAL_HOLD_MS=

# Worker sleep interval when no active event is scheduled for today.
# This prevents the Render worker from polling VolleyballLife/VMIX on off-days.
WORKER_OFF_EVENT_INTERVAL_MS=900000

STREAMRUN_API_KEY=
STREAMRUN_CONFIGURATION_ID=
STREAMRUN_BASE_URL=https://streamrun.com

# Commentator portal (/commentary). Blank/unset passcode disables the portal.
COMMENTATOR_PASSCODE=
# Self-hosted LiveKit commentary. The public URL is safe for clients; API
# credentials are server-only and mint short-lived court-scoped tokens.
NEXT_PUBLIC_LIVEKIT_COMMENTARY_URL=
LIVEKIT_COMMENTARY_API_KEY=
LIVEKIT_COMMENTARY_API_SECRET=
LIVEKIT_COMMENTARY_ROOM_PREFIX=scorecheck-court-

# Program pages (/program/court/{n}) — the compositor scenes a headless-Chrome
# LiveKit egress captures and pushes to YouTube. Gates both the page (?token=)
# and /api/program/heartbeat. Blank/unset disables program pages (plain 404).
PROGRAM_PAGE_TOKEN=

# Production controller (infra/controller) — the /admin/production console's
# broadcast start/stop proxy target, e.g. http://10.0.0.5:8080. Unset/blank
# renders the console's "controller offline" state and disables broadcast
# buttons (expected until the compositor fleet ships).
CONTROLLER_URL=
CONTROLLER_TOKEN=

# ---------------------------------------------------------------------------
# Live-chat monitor (/chat) — one window showing YouTube live-chat from every
# court stream, each message tagged with a colour-coded COURT badge.
# ---------------------------------------------------------------------------
# Master switch for the worker's chat polling. Off by default so the feature
# spends zero YouTube quota until you opt in. Set to "true" to enable.
YOUTUBE_CHAT_ENABLED=false
# Auth for the official YouTube Data API v3. Configure EITHER an API key (works
# for reading public live chats) OR the OAuth trio (preferred — more reliable).
# When both are set the reader uses OAuth. When neither is set the feature is
# cleanly disabled (worker skips, /chat shows "YouTube API not configured").
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
# Quota throttle. liveChatMessages.list costs ~5 units/call and videos.list ~1;
# the default project quota is 10,000 units/day. At the 180s default, 8 streams
# over a ~10h day cost roughly 8,000 units — safely under quota. Lower it toward
# real-time only after Google grants a quota increase. Min 15000 (15s).
YOUTUBE_CHAT_POLL_INTERVAL_MS=180000
# Hard daily-unit budget guard. The reader tracks units spent (reset on UTC day
# change) and STOPS polling for the day once this is exceeded, so it can never
# blow the quota. Keep it under your real daily quota. Default 9000.
YOUTUBE_CHAT_DAILY_UNIT_BUDGET=9000
# Standalone passcode for /chat (commentators + on-site emcees use it on their
# phones). Signed httpOnly cookie, 24h, HMAC'd with ADMIN_SECRET; it does NOT
# grant admin. Blank/unset disables /chat with a clear message.
CHAT_MONITOR_PASSCODE=

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
