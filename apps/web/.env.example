NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_DEFAULT_EVENT_SLUG=avp-denver
NEXT_PUBLIC_EVENT_NAME="AVP Denver Open"
NEXT_PUBLIC_COURT_COUNT=8
NEXT_PUBLIC_DEFAULT_TIMEZONE=America/Denver

# MediaMTX self-hosted video (see docs/MEDIAMTX_DIGITALOCEAN_SETUP.md)
# WHEP base example: https://live.example.com (or http://1.2.3.4:8889 for testing)
# HLS base example: https://live.example.com/hls (or http://1.2.3.4:8888 for testing)
MEDIAMTX_WHEP_BASE_URL=
MEDIAMTX_HLS_BASE_URL=
MEDIAMTX_READ_USER=
MEDIAMTX_READ_PASS=
# Used by setup scripts/docs only, e.g. rtmp://1.2.3.4:1935
MEDIAMTX_RTMP_INGEST_BASE=

# Optional per-court MediaMTX path overrides (default: court{n})
COURT_1_STREAM_PATH=
COURT_2_STREAM_PATH=
COURT_3_STREAM_PATH=
COURT_4_STREAM_PATH=
COURT_5_STREAM_PATH=
COURT_6_STREAM_PATH=
COURT_7_STREAM_PATH=
COURT_8_STREAM_PATH=

# Post-final overlay hold before auto-advancing to the next queued match
# (milliseconds, 0-3600000; blank/invalid falls back to 180000)
VBL_POST_FINAL_HOLD_MS=

# Worker sleep interval when no active event is scheduled for today.
# This prevents the Render worker from polling VolleyballLife/VMIX on off-days.
WORKER_OFF_EVENT_INTERVAL_MS=900000

STREAMRUN_API_KEY=
STREAMRUN_CONFIGURATION_ID=
STREAMRUN_BASE_URL=https://streamrun.com

# Commentator portal (/commentary). Blank/unset passcode disables the portal.
COMMENTATOR_PASSCODE=
# VDO.Ninja rooms are {prefix}{streamNumber}, e.g. BVMCOURT3.
# Keep prefix and password alphanumeric — VDO.Ninja rejects punctuation.
VDO_ROOM_PREFIX=BVMCOURT
VDO_ROOM_PASSWORD=bvm2026
# Delay applied to commentary audio in the StreamRun scene link so it lines up
# with the delayed program video (milliseconds, 0-4000; blank/invalid -> 2000)
VDO_SCENE_BUFFER_MS=2000

# Program pages (/program/court/{n}) — the compositor scenes a headless-Chrome
# LiveKit egress captures and pushes to YouTube. Gates both the page (?token=)
# and /api/program/heartbeat. Blank/unset disables program pages (plain 404).
PROGRAM_PAGE_TOKEN=

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
