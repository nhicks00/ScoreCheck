# Shared
MONITOR_AGENT_TOKEN=replace-with-a-long-random-token
MONITOR_API_TOKEN=replace-with-a-different-long-random-token
ALERTMANAGER_WEBHOOK_TOKEN=replace-with-a-third-long-random-token
ALERTMANAGER_INTERNAL_URL=http://alertmanager:9093
MONITOR_BROWSER_HEARTBEAT_SECRET=replace-with-at-least-32-random-characters
MONITOR_BROWSER_ALLOWED_ORIGINS=https://score.beachvolleyballmedia.com,http://localhost:3000

# Host agent
MONITOR_AGENT_ID=bvm-preview-01
MONITOR_AGENT_ROLE=mediamtx
MONITOR_AGENT_BIND=127.0.0.1
MONITOR_AGENT_PORT=9108
MONITOR_AGENT_INTERVAL_MS=5000
MONITOR_AGENT_CONTAINERS=mediamtx
MONITOR_DISK_PATH=/
FFMPEG_PROGRESS_DIR=/monitoring/ffmpeg
DOCKER_API_URL=http://127.0.0.1:2375
MEDIAMTX_API_URL=http://127.0.0.1:9997
MEDIAMTX_METRICS_URL=http://127.0.0.1:9998/metrics
LIVEKIT_METRICS_URL=
EGRESS_METRICS_URL=
EGRESS_HEALTH_URL=
MONITOR_EGRESS_MAX_WEB_REQUESTS=1
# Compositor-only raw camera picture/audio analyzer. Assign exactly one analyzer
# per live camera. Keep this URL credential-free and private to the media plane.
MONITOR_CONTENT_ANALYZER_COURTS=
MONITOR_CONTENT_ANALYZER_RTSP_BASE_URL=
MONITOR_CONTENT_ANALYZER_FFMPEG_PATH=/usr/bin/ffmpeg
MONITOR_CONTENT_ANALYZER_FFPROBE_PATH=/usr/bin/ffprobe

# Observability service. Format: id|role|URL|token|courts, separated by commas.
# Courts use '+' inside an entry; only compositors own courts. Keep the final '|'
# for targets without court ownership.
MONITOR_AGENT_TARGETS=bvm-preview-01|mediamtx|http://10.120.0.2:9108|replace-token|,bvm-compositor-a|compositor|http://10.120.0.3:9108|replace-token|1+2
MONITOR_SERVICE_BIND=127.0.0.1
MONITOR_SERVICE_PORT=9110
MONITOR_SERVICE_INTERVAL_MS=5000
MONITOR_COURT_COUNT=8

# Optional independent dead-man checks. Treat both URLs as secrets. Configure
# both URLs, both ids, and the API key together. The active check is pinged only
# while at least one court is expected on; channel attachment is audited read-only.
HEALTHCHECKS_BASELINE_PING_URL=
HEALTHCHECKS_BASELINE_CHECK_ID=
HEALTHCHECKS_ACTIVE_PING_URL=
HEALTHCHECKS_API_KEY=
HEALTHCHECKS_ACTIVE_CHECK_ID=
HEALTHCHECKS_BASELINE_INTERVAL_MS=600000
HEALTHCHECKS_ACTIVE_INTERVAL_MS=60000
HEALTHCHECKS_CHANNEL_AUDIT_INTERVAL_MS=300000

# Durable incidents and checkpoints (service only).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Quota-aware YouTube monitor. OAuth enables ingestion health; an API key only
# provides public broadcast lifecycle. No requests are made while broadcasts
# are expected off.
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_MONITOR_INTERVAL_MS=60000

# Notification providers (service only).
MONITOR_DASHBOARD_URL=https://score.beachvolleyballmedia.com/admin/monitor
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
NOTIFICATION_STATUS_INTERVAL_MS=30000
