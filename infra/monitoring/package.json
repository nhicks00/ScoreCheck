{
  "name": "scorecheck-monitoring",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src && node --test capture-fault-evidence.test.mjs run-test-feed-fault.test.mjs",
    "dev:agent": "tsx src/agent.ts",
    "dev:service": "tsx src/service.ts",
    "start:agent": "node dist/agent.js",
    "start:service": "node dist/service.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "express": "^5.1.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
