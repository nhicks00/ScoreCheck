# BVM production controller — environment template (cp .env.example .env).
# .env is gitignored (root: infra/**/.env). Never commit real values.

# Bearer token /admin/production must present. Generate: openssl rand -hex 32
CONTROLLER_TOKEN=

# LiveKit Egress API (the infra/compositor stack). Same keypair as its .env.
LIVEKIT_URL=http://127.0.0.1:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Program pages (court N -> ${PROGRAM_PAGE_BASE_URL}/${N}?token=${PROGRAM_PAGE_TOKEN})
PROGRAM_PAGE_BASE_URL=https://score.beachvolleyballmedia.com/program/court
PROGRAM_PAGE_TOKEN=changeme

# YouTube RTMP base; per-court keys via COURT_<N>_YOUTUBE_KEY until Phase 3
# moves them into Supabase (encrypted).
YOUTUBE_RTMP_BASE=rtmp://a.rtmp.youtube.com/live2
COURT_1_YOUTUBE_KEY=

# HTTP port (default 8080)
#CONTROLLER_PORT=8080

# Default encoding preset for started courts (H264_720P_30 | H264_1080P_30)
#EGRESS_PRESET=H264_720P_30
