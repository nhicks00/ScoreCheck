# BVM production controller — environment template (cp .env.example .env).
# .env is gitignored (root: infra/**/.env). Never commit real values.

# Bearer token /admin/production must present. Generate: openssl rand -hex 32
CONTROLLER_TOKEN=

# LiveKit Egress API (the infra/compositor stack). Same keypair as its .env.
LIVEKIT_URL=http://127.0.0.1:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Immutable event renderer. The token is carried only in the bootstrap URL
# fragment and exchanged for an HttpOnly court/build/deployment session.
PROGRAM_PAGE_BASE_URL=https://REPLACE-UNIQUE-DEPLOYMENT.vercel.app/program
PROGRAM_PAGE_TOKEN=changeme
PROGRAM_RENDERER_GIT_SHA=
PROGRAM_RENDERER_DEPLOYMENT_ID=

# YouTube RTMPS base; per-court keys via COURT_<N>_YOUTUBE_KEY until Phase 3
# moves them into Supabase (encrypted).
YOUTUBE_RTMPS_BASE=rtmps://a.rtmps.youtube.com/live2
COURT_1_YOUTUBE_KEY=

# Required final-output profile. Monitoring renditions are configured elsewhere
# and never change this YouTube output contract.
PRODUCTION_OUTPUT_PROFILE=1080p30

# HTTP port (default 8080)
#CONTROLLER_PORT=8080

# Encoding is 1920x1080 H.264 High at 10 Mbps/30 fps or 12 Mbps/60 fps,
# two-second keyframes, and AAC 48 kHz at 128 kbps.
