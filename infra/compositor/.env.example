# BVM compositor stack — environment template.
#
#   cp .env.example .env    # then fill in the blanks
#
# .env is consumed by BOTH docker compose (variable substitution in
# docker-compose.yml) and the court scripts (start/stop/list, which source it).
# It is gitignored (root .gitignore: infra/**/.env) — never commit real values.

# --- LiveKit API keypair (shared by livekit-server, egress worker, scripts) ---
# Generate a fresh pair with:
#   docker run --rm livekit/livekit-server generate-keys
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit Egress API endpoint used by the court scripts (lk CLI). The default
# matches the 127.0.0.1:7880 binding in docker-compose.yml; point it at the
# droplet's address instead if you run the scripts from another machine.
LIVEKIT_URL=http://127.0.0.1:7880

# --- Program pages (the scene being captured) ---------------------------------
# Court N's scene URL is built as: ${PROGRAM_PAGE_BASE_URL}/${N}?token=${PROGRAM_PAGE_TOKEN}
PROGRAM_PAGE_BASE_URL=https://score.beachvolleyballmedia.com/program/court
# Access token for the token-gated program pages (Phase 1 deliverable).
PROGRAM_PAGE_TOKEN=changeme

# --- YouTube RTMPS distribution ------------------------------------------------
# Ingest base; the per-court stream key is appended. Plain RTMP is intentionally
# unsupported by the Gate 1 script.
YOUTUBE_RTMPS_BASE=rtmps://a.rtmps.youtube.com/live2

# Per-court stream keys (YouTube Studio -> Go live -> Stream settings).
# Phase 2 gating experiment: use a key from an UNLISTED broadcast.
COURT_1_YOUTUBE_KEY=
#COURT_2_YOUTUBE_KEY=
#COURT_3_YOUTUBE_KEY=
#COURT_4_YOUTUBE_KEY=
#COURT_5_YOUTUBE_KEY=
#COURT_6_YOUTUBE_KEY=
#COURT_7_YOUTUBE_KEY=
#COURT_8_YOUTUBE_KEY=

# --- Encoding ------------------------------------------------------------------
# Explicit YouTube 720p30 profile. Values are kbps, Hz, and seconds.
EGRESS_WIDTH=1280
EGRESS_HEIGHT=720
EGRESS_FRAMERATE=30
EGRESS_VIDEO_BITRATE=4000
EGRESS_AUDIO_BITRATE=128
EGRESS_AUDIO_FREQUENCY=48000
EGRESS_KEYFRAME_INTERVAL=2
