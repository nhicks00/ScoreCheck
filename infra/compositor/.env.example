# BVM compositor stack — environment template.
#
#   cp .env.example .env    # then fill in the blanks
#
# .env is consumed by BOTH docker compose (variable substitution in
# docker-compose.yml) and the court scripts (start/stop/list, which source it).
# It is gitignored (root .gitignore: infra/**/.env) — never commit real values.

# --- LiveKit API keypair (shared by livekit-server, egress worker, scripts) ---
# Generate a fresh pair with:
#   docker run --rm livekit/livekit-server generate-keys
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Generated from the protected event venue profile. Direct-H264 cameras keep
# CAMERA_NORMALIZER_ENABLED=false. HEVC cameras use their owning compositor and
# the ingest Droplet's private VPC address; never set this to a public address.
CAMERA_NUMBER=
CAMERA_SOURCE_PATH_MODE=inactive
CAMERA_SOURCE_CODEC=NONE
CAMERA_SOURCE_PROFILE=NONE
CAMERA_FRAME_RATE_MODE=NONE
CAMERA_NORMALIZER_ENABLED=false
CAMERA_NORMALIZER_INPUT_PATH=
CAMERA_NORMALIZER_OUTPUT_PATH=
MEDIAMTX_PRIVATE_HOST=

# LiveKit Egress API endpoint used by the court scripts (lk CLI). The default
# matches the 127.0.0.1:7880 binding in docker-compose.yml; point it at the
# droplet's address instead if you run the scripts from another machine.
LIVEKIT_URL=http://127.0.0.1:7880

# --- Program pages (the scene being captured) ---------------------------------
# The event controller writes the exact generated deployment URL, never the
# mutable production alias. Court N first loads /program/bootstrap and exchanges
# this token from a URL fragment for a scoped HttpOnly session cookie.
PROGRAM_PAGE_BASE_URL=https://REPLACE-UNIQUE-DEPLOYMENT.vercel.app/program
PROGRAM_PAGE_TOKEN=changeme
PROGRAM_RENDERER_GIT_SHA=
PROGRAM_RENDERER_DEPLOYMENT_ID=

# --- YouTube RTMPS distribution ------------------------------------------------
# Ingest base; the per-court stream key is appended. Plain RTMP is intentionally
# unsupported by the Gate 1 script.
YOUTUBE_RTMPS_BASE=rtmps://a.rtmps.youtube.com/live2

# Per-camera reusable variable-profile stream identities. Production startup
# probes the native source and passes either 1080p30 or 1080p60 explicitly to
# start-court.sh; these values never choose the encoder profile themselves.
COURT_1_YOUTUBE_KEY=
COURT_1_YOUTUBE_STREAM_ID=
#COURT_2_YOUTUBE_KEY=
#COURT_2_YOUTUBE_STREAM_ID=
#COURT_3_YOUTUBE_KEY=
#COURT_3_YOUTUBE_STREAM_ID=
#COURT_4_YOUTUBE_KEY=
#COURT_4_YOUTUBE_STREAM_ID=
#COURT_5_YOUTUBE_KEY=
#COURT_5_YOUTUBE_STREAM_ID=
#COURT_6_YOUTUBE_KEY=
#COURT_6_YOUTUBE_STREAM_ID=
#COURT_7_YOUTUBE_KEY=
#COURT_7_YOUTUBE_STREAM_ID=
#COURT_8_YOUTUBE_KEY=
#COURT_8_YOUTUBE_STREAM_ID=

# Rebuild-time contract metadata. The corresponding YouTube streams must keep
# variable resolution/frame-rate auto-detection enabled.
YOUTUBE_STREAM_RESOLUTION=variable
YOUTUBE_STREAM_FRAME_RATE=variable
PRODUCTION_OUTPUT_PROFILES=1080p30,1080p60
