#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

ROUTING_TOOL=/usr/sbin/scorecheck-speedify-routing

start_service() {
  procd_open_instance
  procd_set_param command "$ROUTING_TOOL" watch
  procd_set_param respawn 5 5 0
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_close_instance
}

reload_service() {
  "$ROUTING_TOOL" guard-if-enabled
}

service_triggers() {
  procd_add_reload_trigger firewall
}
